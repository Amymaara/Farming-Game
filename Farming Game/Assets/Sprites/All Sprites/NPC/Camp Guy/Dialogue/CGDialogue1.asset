  npcName: Camp Guy
  npcPortrait: {fileID: 5754670671140466535, guid: 1b8135b0080cf61468de419c21eb4d29, type: 3}
  typingSpeed: 0.05
  voiceSound: {fileID: 0}
  voicePitch: 1
  dialogueLines:
  - '"Huh? A new face?"'
  - '"You don''t see that often around these parts."'
  - '"What am I doing here?"'
  - '"Isn''t it obvious. The bridge to town is broken."'
  - '"I mean, i''m not stuck."'
  - '"I can fix the bridge easily."'
  - '"Well hold your horses"'
  - '"A man''s gotta eat."'
  - '"Tell you what, bring me some vegetable for my stew and i''ll fix the bridge
    for you."'
  - '"Yup, bring me back some tomatoes, have some seeds in the chest you can use."'
  - '"Well just plant em, I aint a farmer. There''s some tomato seeds in the chest
    though."'
  - '"How''s the farming going?"'
  - '"That was definetely needed, but I think it''s still missing something."'
  autoProgressLines: 000000000000010101000000
  endDialogueLines: 000000000000000001010101
  autoProgressDelay: 1.5
  choices:
  - dialogueIndex: 5
    choices:
    - '"Oh great! We can finally make it to town."'
    - '"So why is it still broken?"'
    nextDialogueIndexes: 0600000006000000
    givesQuest: 0000
  - dialogueIndex: 7
    choices:
    - '" So we''re stuck until i feed you?"'
    - '" Sure! how do I get them to you?"'
    nextDialogueIndexes: 090000000a000000
    givesQuest: 0101
